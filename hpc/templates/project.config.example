# 實驗/任務參數（每個實驗可複製後自行調整）

export EXP_NAME="${EXP_NAME:-dino_visa_a0_linear}"

# DINOv3 model cache. MODEL_PATH 可指向本機已下載 checkpoint。
export MODEL_ID="${MODEL_ID:-facebook/dinov3-vitb16-pretrain-lvd1689m}"
export MODEL_PATH="${MODEL_PATH:-$WORK_DIR/models/dinov3-vitb16-pretrain-lvd1689m}"

# VisA dataset root and supervised split.
export DATASET_ROOT="${DATASET_ROOT:-$WORK_DIR/datasets/VisA}"
export SPLIT_CSV="${SPLIT_CSV:-split_csv/2cls_highshot.csv}"

# Baseline settings.
export HEAD="${HEAD:-linear}"
export FEATURE="${FEATURE:-cls}"
export TOP_K="${TOP_K:-6}"
export PATCH_PROJECTOR_DEPTH="${PATCH_PROJECTOR_DEPTH:-6}"
export PATCH_PROJECTOR_HEADS="${PATCH_PROJECTOR_HEADS:-8}"
export PATCH_PROJECTOR_DROPOUT="${PATCH_PROJECTOR_DROPOUT:-0.1}"
export EPOCHS="${EPOCHS:-5}"
export BATCH_SIZE="${BATCH_SIZE:-16}"
export NUM_WORKERS="${NUM_WORKERS:-4}"
export LR="${LR:-1e-3}"
export WEIGHT_DECAY="${WEIGHT_DECAY:-1e-4}"
export SEED="${SEED:-42}"
export AMP="${AMP:-1}"
